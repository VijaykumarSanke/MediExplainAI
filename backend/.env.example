# ============================================================
# MediExplain AI – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The backend will automatically load this via python-dotenv.
# Changes: OPENAI_API_KEY replaced with GROQ_API_KEY,
#          added JWT_SECRET, DATABASE_URL, ALLOWED_ORIGINS
# ============================================================

# --- Groq API Key (REQUIRED for AI features) ---
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# --- JWT Authentication Secret (REQUIRED for user auth) ---
# Use a strong random string in production, e.g.: openssl rand -hex 32
JWT_SECRET=mediexplainai-change-this-to-a-strong-random-secret

# --- Database URL (default: SQLite in project root) ---
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./mediai.db
# PostgreSQL example: DATABASE_URL=postgresql://user:pass@localhost/mediexplain

# --- CORS Allowed Origins ---
# Comma-separated list of allowed frontend origins.
# Use * to allow all (development only).
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# --- Optional: API server settings ---
# HOST=0.0.0.0
# PORT=8000
